POSTGRES_DB=madrigal
POSTGRES_USER=madrigal
POSTGRES_PASSWORD=password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_SECRET_KEY=key
BACKEND_ALLOWED_ORIGINS=http://localhost:3000
BACKEND_COOKIE_NAME=predict_mv_session
BACKEND_COOKIE_SECURE=false
BACKEND_CSRF_COOKIE_NAME=predict_mv_csrf
BACKEND_CSRF_HEADER_NAME=X-CSRF-Token

PUBLIC_WEB_BASE_URL=http://localhost:3000
AUTH_ACCESS_TOKEN_TTL_MINUTES=30
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_EMAIL_CODE_TTL_MINUTES=10
AUTH_PASSWORD_RESET_TTL_MINUTES=60
AUTH_CHALLENGE_TTL_MINUTES=10
AUTH_REAUTH_TTL_MINUTES=10
AUTH_CODE_MAX_ATTEMPTS=5
MACHINE_REGISTRATION_TTL_MINUTES=15
MACHINE_INVITE_TTL_HOURS=72
MACHINE_HEARTBEAT_STALE_MINUTES=5
DATA_ENCRYPTION_KEY=key
API_KEY_PEPPER=key

TELEGRAM_BOT_TOKEN=api
TELEGRAM_WEBHOOK_SECRET=key
TELEGRAM_BOT_USERNAME=username
TELEGRAM_LINK_TTL_MINUTES=15
TELEGRAM_INTERNAL_SIGNING_SECRET=key
INTERNAL_REQUEST_TTL_SECONDS=300

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-mail@yandex.ru
SMTP_PASS=replace-with-app-password
EMAIL_FROM=your-mail@yandex.ru
SUPPORT_EMAIL=support@predictmv.local
BRAND_DISPLAY_NAME=Predict MV

TLS_CERT_PATH=/run/secrets/server.crt
TLS_KEY_PATH=/run/secrets/server.key
TLS_CA_PATH=/run/secrets/ca.crt
