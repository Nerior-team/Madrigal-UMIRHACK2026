<service>
  <id>PredictMV</id>
  <name>PredictMV</name>
  <description>PredictMV background agent service</description>
  <executable>%BASE%\PredictMV.exe</executable>
  <workingdirectory>%BASE%</workingdirectory>
  <env name="APPDATA" value="C:\ProgramData" />
  <log mode="roll-by-size">
    <sizeThreshold>10485760</sizeThreshold>
    <keepFiles>5</keepFiles>
    <pattern>C:\ProgramData\PredictMV\logs\PredictMV</pattern>
  </log>
  <onfailure action="restart" delay="10 sec" />
</service>
